# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=yugioh
POSTGRES_PASSWORD=yugioh_secret
POSTGRES_DB=yugioh
DATABASE_URL=postgresql://yugioh:yugioh_secret@db:5432/yugioh

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_VISION_MODEL=llama3.2-vision:11b
OLLAMA_TEXT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_in_production_please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
AI_SERVICE_URL=http://ai:8000
APP_ENV=development

# ─── Storage paths ────────────────────────────────────────────────────────────
UPLOAD_DIR=/storage/uploads
THUMBNAIL_DIR=/storage/thumbnails
EXPORT_DIR=/storage/exports
SCRAPED_DIR=/storage/scraped

# ─── Rate limits ──────────────────────────────────────────────────────────────
RATE_LIMIT_AI_RPM=30
RATE_LIMIT_UPLOAD_RPM=10

# ─── Scraping ─────────────────────────────────────────────────────────────────
YGOPRODECK_API_URL=https://db.ygoprodeck.com/api/v7
SCRAPE_USER_AGENT=YuGiOhTools/1.0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
